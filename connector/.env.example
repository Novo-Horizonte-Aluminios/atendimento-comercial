# Evolution Go Connector — Variáveis de Ambiente

# ================================
# SERVIDOR
# ================================
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ================================
# CONNECTOR SECRET (gerado automaticamente pelo Kanban)
# Use: openssl rand -hex 32
# ================================
CONNECTOR_SECRET=sua-chave-secreta-32-chars-aqui

# ================================
# EVOLUTION GO
# ================================
EVOLUTION_API_URL=https://api2.emersontorres.com.br
EVOLUTION_API_KEY=evolution-global-apikey-2026

# ================================
# CHATWOOT
# ================================
CHATWOOT_API_URL=https://atendimento.emersontorres.com.br
CHATWOOT_PLATFORM_API_TOKEN=SEU_TOKEN_DE_PLATAFORMA_AQUI
# Obtenha em: Chatwoot > Super Admin > API Access Token

# ================================
# KANBAN (auto-preenchido pelo Kanban backend)
# ================================
KANBAN_API_URL=https://kanban.emersontorres.com.br
KANBAN_INTERNAL_URL=http://backend:3000

# ================================
# WEBHOOK (URL interna do conector - sem subdomínio público)
# ================================
CONNECTOR_WEBHOOK_URL=http://evo_go_connector:3000

# ================================
# CHATWOOT DATABASE (para sync direto se necessário)
# ================================
CHATWOOT_DATABASE_URL=postgresql://postgres:Chatwoot_DB_P@ssw0rd!2026@postgrescw:5432/chatwoot
